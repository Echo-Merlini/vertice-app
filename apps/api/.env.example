# ─── App ───────────────────────────────────────────────
APP_URL=http://localhost:3000
PORT=3000

# ─── Database (Supabase Postgres) ──────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:54321/postgres

# ─── Better Auth ───────────────────────────────────────
BETTER_AUTH_SECRET=change-me-32-chars-minimum-secret
BETTER_AUTH_URL=http://localhost:3000

# ─── Google OAuth ──────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Resend ────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com

# ─── Stripe ────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxx

# ─── Push Service ──────────────────────────────────────
PUSH_SERVICE_URL=http://192.168.68.52:8090/push
PUSH_SERVICE_TOKEN=

# ─── Crypto / RPC ──────────────────────────────────────
# Optional — falls back to public RPCs if unset (rate-limited, not for production)
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# ─── SIWE ──────────────────────────────────────────────
SIWE_DOMAIN=localhost
SIWE_STATEMENT=Sign in to GoBoiler

# ─── AI Agent ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxx
GROQ_API_KEY=gsk_xxxxxxxxxxxx
MISTRAL_API_KEY=xxxxxxxxxxxx
DEFAULT_AI_MODEL=claude-sonnet-4-6

# ─── Admin ────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me-strong-password
